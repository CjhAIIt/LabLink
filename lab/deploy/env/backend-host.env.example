SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8081

DB_URL=jdbc:mysql://127.0.0.1:3306/lab_recruitment?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>

JWT_SECRET=<JWT_SECRET>

MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=<MAIL_USERNAME>
MAIL_PASSWORD=<MAIL_PASSWORD>

FILE_UPLOAD_PATH=/opt/lablink/uploads/public/
FILE_PROTECTED_UPLOAD_PATH=/opt/lablink/uploads/protected/
APP_LOG_FILE=/opt/lablink/logs/application.log

APP_ALLOWED_ORIGIN_PRIMARY=https://lablink.example.com
APP_ALLOWED_ORIGIN_SECONDARY=https://www.lablink.example.com
TRUST_FORWARD_HEADERS=true
APP_SCHEMA_RUNTIME_UPDATE_ENABLED=false
APP_SCHEMA_MIGRATION_ENABLED=true

LABLINK_CACHE_REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

LABLINK_MQ_RABBIT_ENABLED=false
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

JUDGE_PYTHON_COMMAND=python3
JUDGE_C_COMPILER_COMMAND=gcc
JUDGE_CPP_COMPILER_COMMAND=g++
JUDGE_JAVA_COMPILER_COMMAND=javac
JUDGE_JAVA_COMMAND=java
JUDGE_WORK_DIR=/opt/lablink/judge-work

AI_API_KEY=<AI_API_KEY>
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

GRADPATH_BASE_URL=https://lablink.example.com
GRADPATH_WS_URL=wss://lablink.example.com/ws/interview
