{
  "name": "lablink-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "LabLink 高校实验室管理平台多端前端",
  "author": "LabLink Team",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "desktop:start": "electron .",
    "desktop:dist": "electron-builder --win portable --config.win.signAndEditExecutable=false",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.6.0",
    "dayjs": "^1.11.19",
    "echarts": "^5.6.0",
    "element-plus": "^2.4.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "recorder-core": "^1.3.25011100",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@vitejs/plugin-vue": "^4.4.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.0.0",
    "vite": "^4.4.0"
  },
  "build": {
    "appId": "com.aiit.labmanagement.desktop",
    "productName": "LabLink",
    "directories": {
      "output": "desktop-release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
